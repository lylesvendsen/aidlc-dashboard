# AIDLC Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NEVER be committed.
# .env.local.example IS committed — it is safe to share.

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Data directory for project configs
# AIDLC_DATA_DIR=./data

# Optional: Override base directory for relative path resolution.
# When set, relative paths like ../overboardom-app resolve from this directory.
# Default: parent directory of the dashboard.
# AIDLC_BASE_DIR=/Users/yourname/Projects

# Optional: Override the default Claude model
# AIDLC_MODEL=claude-sonnet-4-6

# Optional: Override max output tokens
# AIDLC_MAX_TOKENS=8192

# Run terminal — default on/off state for each filter toggle in the UI (GET /api/log-config).
# These only affect which lines are shown in the browser; the saved execution log always includes every line.
# AIDLC_LOG_DISPLAY_ERRORS=true
# AIDLC_LOG_DISPLAY_SUCCESS=true
# AIDLC_LOG_DISPLAY_INFO=true
# AIDLC_LOG_DISPLAY_SYSTEM=false